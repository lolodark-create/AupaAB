---
import { TRENDING } from '@shared/mock';
---

<section aria-labelledby="trending-heading">
  <h3 id="trending-heading" class="font-serif font-semibold text-[17px] tracking-[-0.005em] mb-4">
    Le plus lu cette semaine
  </h3>
  <ol class="m-0 p-0 list-none flex flex-col">
    {TRENDING.map((t) => (
      <li class="border-b border-border-subtle">
        <a href={`/article/${t.slug}`} class="flex gap-3.5 items-baseline py-3.5 hover:opacity-80">
          <span
            class="font-serif font-semibold text-[32px] leading-none w-8 shrink-0 tnum text-aviron"
            style="font-variation-settings:'opsz' 96;"
            aria-hidden="true"
          >
            {t.rank}
          </span>
          <span class="font-serif font-medium text-[15px] leading-[1.3] text-fg">{t.title}</span>
        </a>
      </li>
    ))}
  </ol>
</section>
