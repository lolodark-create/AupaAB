---
// AUPA AB logo — sky-blue square with stacked "AUPA / AB" in heavy white
// sans-serif. The icon itself reads as the wordmark, so we don't repeat
// 'AUPA AB' next to it (was redundant in the desktop header). The
// `variant` prop is kept for API stability but both values now render
// just the mark.
interface Props {
  variant?: 'full' | 'mark';
  size?: number;
  class?: string;
}
const { size = 36, class: className } = Astro.props;
---

<a href="/" class:list={['inline-flex items-center group', className]} aria-label="AUPA AB — accueil">
  <span
    class="inline-flex items-center justify-center rounded-md shrink-0 bg-ciel overflow-hidden"
    style={`width:${size}px; height:${size}px;`}
    aria-hidden="true"
  >
    {/* viewBox 100×100 so font-size values are percentage-ish; SVG <text>
        scales linearly with the outer rect. Heavy weight + tight letter
        spacing reproduces the reference image's slab-like presence. */}
    <svg viewBox="0 0 100 100" width={size} height={size} xmlns="http://www.w3.org/2000/svg" role="img">
      <title>AUPA AB</title>
      <text
        x="50" y="45"
        text-anchor="middle"
        fill="white"
        font-family="-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI Black', 'Arial Black', system-ui, sans-serif"
        font-weight="900"
        font-size="32"
        letter-spacing="-2"
      >AUPA</text>
      <text
        x="50" y="86"
        text-anchor="middle"
        fill="white"
        font-family="-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI Black', 'Arial Black', system-ui, sans-serif"
        font-weight="900"
        font-size="32"
        letter-spacing="-2"
      >AB</text>
    </svg>
  </span>
</a>
