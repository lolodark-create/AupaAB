const ariaHidden = rest['aria-label'] ? 'false' : 'true';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={ariaHidden}
  aria-label={rest['aria-label']}
  role={rest['aria-label'] ? 'img' : undefined}
  set:html={paths[name]}
/>
