---
// Article thumbnail: real source image when available, source-brand chip
// fallback otherwise.
//
// We hot-link the image from the source CDN (Sud Ouest, Midol, Rugbyrama…)
// rather than rehosting — bandwidth stays with the source, which is the
// standard aggregator-friendly behavior. If the image fails to load (404,
// CDN block, slow server, etc.), the EditorialThumb chip is already
// rendered behind it via absolute positioning, so the user always sees
// something.
//
// referrerpolicy="no-referrer" prevents leaking the AUPA domain to the
// source server in the Referer header — privacy hygiene, and avoids some
// hot-link blockers that key on referrer.
//
// loading="lazy" defers off-screen images and keeps the LCP fast.
import EditorialThumb from './EditorialThumb.astro';
import type { ArticleCategory } from '@shared/types';

type Size = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  id: string;
  title: string;
  category: ArticleCategory;
  dateLabel?: string;
  sourceSlug: string;
  sourceName: string;
  coverImageUrl?: string | null;
  size?: Size;
  class?: string;
}

const { coverImageUrl, ...rest } = Astro.props;
---

<div class:list={['relative isolate w-full h-full overflow-hidden bg-night', rest.class]}>
  {/* `isolate` creates a new stacking context here. Without it, the img's
      z-10 escaped to the root and collided with the sticky filter bar
      (also z-10) — the photo painted over the chips while scrolling. */}
  <div class="absolute inset-0 z-0">
    <EditorialThumb {...rest} />
  </div>
  {coverImageUrl && (
    <img
      src={coverImageUrl}
      alt={`Photo illustrant : ${rest.title}`}
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer"
      class="absolute inset-0 z-10 w-full h-full object-cover"
      onerror="this.remove()"
    />
  )}
</div>
