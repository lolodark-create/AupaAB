---
// MatchBanner — brief design §9.1 + §8.x.
import Icon from './atoms/Icon.astro';

interface TeamForm {
  short: string;
  form: ReadonlyArray<'V' | 'D' | 'N'>;
}

interface Props {
  home: TeamForm;
  away: TeamForm;
  venue: string;
  kickoff: string;
  competition: string;
  diffusion: string;
  daysOut: number;
  countdownPct?: number;
  class?: string;
}

const { home, away, venue, kickoff, competition, diffusion, daysOut, countdownPct = 38, class: className } = Astro.props;

const resultColor = (r: 'V' | 'D' | 'N') =>
  r === 'V' ? '#2F8F4F' : r === 'D' ? '#D52B1E' : '#5A6472';
---

<section
  class:list={['relative overflow-hidden rounded-lg text-[#FAFAF7]', className]}
  style="background: rgb(11 37 69); padding: clamp(20px, 4vw, 28px) clamp(20px, 4vw, 32px);"
  aria-label={`Prochain match : ${home.short} contre ${away.short}, ${kickoff}`}
>
  {/* Lauburu watermark */}
  <svg
    class="absolute -right-8 top-1/2 -translate-y-1/2 opacity-[0.07] pointer-events-none"
    width="280" height="280" viewBox="0 0 100 100"
    aria-hidden="true"
  >
    <g stroke="#3FB0E5" fill="none" stroke-width="0.8">
      <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" />
      <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(90 50 50)" />
      <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(180 50 50)" />
      <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(270 50 50)" />
    </g>
  </svg>

  <div class="relative z-[1] flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
    <div class="flex flex-col gap-1">
      <span class="text-[10.5px] tracking-[0.16em] uppercase font-semibold" style="color:#3FB0E5;">
        Prochain match · J-{daysOut}
      </span>
      <span class="text-[11px] opacity-60 tracking-[0.04em]">
        {competition} · {diffusion}
      </span>
    </div>

    <div class="flex items-center gap-4 md:gap-6 md:flex-1">
      {/* Home */}
      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-md bg-aviron text-white dark:text-night font-bold text-xs tracking-[0.02em]" aria-hidden="true">
            {home.short}
          </span>
          <span class="font-serif font-semibold text-lg leading-none">{home.short}</span>
        </div>
        <div class="flex gap-[3px]" role="list" aria-label={`Forme récente ${home.short}`}>
          {home.form.map((r) => (
            <span
              class="inline-flex items-center justify-center w-[14px] h-[14px] rounded-sm text-[8.5px] font-bold text-white"
              style={`background:${resultColor(r)}`}
              role="listitem"
              aria-label={r === 'V' ? 'Victoire' : r === 'D' ? 'Défaite' : 'Nul'}
            >{r}</span>
          ))}
        </div>
      </div>

      <span class="font-serif italic text-2xl opacity-40 font-normal">vs</span>

      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-md bg-white text-black font-bold text-xs tracking-[0.02em] border-2 border-[#C8102E]" aria-hidden="true">
            {away.short}
          </span>
          <span class="font-serif font-semibold text-lg leading-none">{away.short}</span>
        </div>
        <div class="flex gap-[3px]" role="list" aria-label={`Forme récente ${away.short}`}>
          {away.form.map((r) => (
            <span
              class="inline-flex items-center justify-center w-[14px] h-[14px] rounded-sm text-[8.5px] font-bold text-white"
              style={`background:${resultColor(r)}`}
              role="listitem"
              aria-label={r === 'V' ? 'Victoire' : r === 'D' ? 'Défaite' : 'Nul'}
            >{r}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-1 md:ml-auto">
      <div class="flex items-center gap-2">
        <Icon name="calendar" size={14} />
        <span class="text-[13px] font-medium">{kickoff}</span>
      </div>
      <div class="flex items-center gap-2 opacity-70">
        <Icon name="mapPin" size={14} />
        <span class="text-[12.5px]">{venue}</span>
      </div>
    </div>
  </div>

  {/* Countdown bar (desktop only via hidden md:block on parent equivalent) */}
  <div class="absolute inset-x-0 bottom-0 h-[3px] hidden md:block" style="background: rgba(63,176,229,0.2);">
    <div class="h-full" style={`width:${countdownPct}%; background:#3FB0E5;`} />
  </div>
</section>
