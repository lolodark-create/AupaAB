---
// Editorial auto-thumbnail — brief §7.1. 4 visual variants × 4 sizes.
// Variant is deterministic from the article id unless overridden.
import { getSourceMeta } from '~/lib/sources';
import type { ArticleCategory } from '@shared/types';

type Variant = 'night' | 'sand' | 'aviron' | 'wave';
type Size = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  id: string;
  title: string;
  category: ArticleCategory;
  dateLabel?: string;
  sourceSlug: string;
  sourceName: string;
  size?: Size;
  variant?: Variant;
  class?: string;
}

const { id, title, category, dateLabel, sourceSlug, sourceName, size = 'md', variant, class: className } = Astro.props;
const meta = getSourceMeta(sourceSlug);

// Pick a variant deterministically if not overridden — brief §7.1 (rotation pour éviter monotonie)
function pickVariant(): Variant {
  if (variant) return variant;
  if (category === 'pays_basque') return 'wave';
  const seed = (id.charCodeAt(0) + (id.charCodeAt(1) ?? 0)) % 3;
  return (['night', 'sand', 'aviron'] as const)[seed];
}
const chosen = pickVariant();

// `lg` is used in the hero (featured) card on both mobile and desktop.
// Mobile width 375 with aspect-[16/10] gives ~234px of vertical space, so
// the lg title font needs to fit 4 lines (clamp at viewport).
const tokens: Record<Size, { titleFont: number; padding: number; monoFont: number; lines: number }> = {
  xs: { titleFont: 13, padding: 10, monoFont: 8, lines: 3 },
  sm: { titleFont: 16, padding: 14, monoFont: 9, lines: 3 },
  md: { titleFont: 22, padding: 20, monoFont: 10, lines: 4 },
  lg: { titleFont: 28, padding: 28, monoFont: 11, lines: 4 },
};
const t = tokens[size];

// Use CSS clamp() so the hero title scales up to ~38px on wide viewports
// without overflowing on mobile.
const isHero = size === 'lg';
const titleFontStyle = isHero
  ? 'font-size: clamp(24px, 4vw, 38px)'
  : `font-size: ${t.titleFont}px`;
const padStyle = isHero
  ? 'padding: clamp(20px, 3vw, 44px)'
  : `padding: ${t.padding}px`;

const palettes: Record<Variant, { bg: string; fg: string; filFG: string }> = {
  night: { bg: '#0B2545', fg: '#FAFAF7', filFG: '#3FB0E5' },
  sand: { bg: '#EFEAE0', fg: '#0B2545', filFG: '#0099D8' },
  aviron: { bg: '#0099D8', fg: '#FAFAF7', filFG: '#FAFAF7' },
  wave: { bg: '#0099D8', fg: '#FAFAF7', filFG: '#FAFAF7' },
};
const p = palettes[chosen];

const categoryLabel: Record<ArticleCategory, string> = {
  match: 'Match',
  mercato: 'Mercato',
  coulisses: 'Coulisses',
  espoirs: 'Espoirs',
  pays_basque: 'Pays Basque',
  autre: '',
};
---

<div
  class:list={['relative w-full h-full overflow-hidden flex flex-col justify-between', className]}
  style={`background:${p.bg}; color:${p.fg}; ${padStyle};`}
  role="img"
  aria-label={`${title} — vignette ${sourceName}`}
>
  {/* Filigree per variant */}
  {chosen === 'night' && (
    <svg
      class="absolute -right-[15%] top-1/2 -translate-y-1/2 opacity-[0.06] w-[120%] h-[120%]"
      viewBox="0 0 100 100"
      aria-hidden="true"
    >
      <g stroke={p.filFG} fill="none" stroke-width="0.8">
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(90 50 50)" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(180 50 50)" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(270 50 50)" />
      </g>
    </svg>
  )}
  {chosen === 'sand' && (
    <span
      class="absolute"
      style={`left:${t.padding}px; right:${t.padding}px; bottom:${Math.round(t.padding * 0.7)}px; height:2px; background:rgb(0 153 216);`}
      aria-hidden="true"
    />
  )}
  {chosen === 'wave' && (
    <svg class="absolute inset-0 opacity-[0.18]" width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 100 Q 50 60, 100 100 T 200 100 T 300 100 T 400 100 V 200 H 0 Z" fill={p.filFG} />
      <path d="M0 130 Q 50 100, 100 130 T 200 130 T 300 130 T 400 130 V 200 H 0 Z" fill={p.filFG} opacity="0.5" />
    </svg>
  )}
  {chosen === 'aviron' && (
    <svg class="absolute inset-0 opacity-[0.08]" width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="none" aria-hidden="true">
      {Array.from({ length: 6 }).map((_, i) => (
        <line x1={i * 80} y1="0" x2={i * 80 - 120} y2="200" stroke={p.filFG} stroke-width="40" />
      ))}
    </svg>
  )}

  {/* Top: source mono + date */}
  <div class="relative z-[1] flex items-center justify-between">
    <span class="inline-flex items-center gap-1.5 uppercase font-semibold tracking-[0.1em] opacity-[0.85]" style={`font-size:${t.monoFont + 1}px;`}>
      <span
        class="inline-flex items-center justify-center font-bold rounded-[3px]"
        style={`width:${t.monoFont * 2 + 4}px; height:${t.monoFont * 2 + 4}px;
          background:${chosen === 'night' ? p.fg : chosen === 'sand' ? p.bg : 'rgba(255,255,255,0.2)'};
          color:${chosen === 'night' ? p.bg : chosen === 'sand' ? p.fg : p.fg};
          font-size:${t.monoFont}px;`}
      >
        {meta.mono}
      </span>
      <span>{sourceName}</span>
    </span>
    {size !== 'xs' && dateLabel && (
      <span class="uppercase tracking-[0.08em] font-medium opacity-70" style={`font-size:${t.monoFont + 1}px;`}>
        {dateLabel}
      </span>
    )}
  </div>

  {/* Middle: title.
      Not a real heading — the parent card / page already provides the heading.
      Using <p> avoids breaking heading-order in lists where the thumb appears
      DOM-first inside an article whose <h2> follows. The image already exposes
      the title via aria-label on the role="img" wrapper. */}
  <div class="relative z-[1] flex-1 flex items-center" style={`padding-top:${Math.round(t.padding * 0.4)}px; padding-bottom:${Math.round(t.padding * 0.4)}px;`}>
    <p
      class="font-serif font-semibold m-0 overflow-hidden"
      aria-hidden="true"
      style={`color:${p.fg};
        ${titleFontStyle};
        line-height:1.08;
        letter-spacing:-0.012em;
        font-variation-settings:'opsz' 96, 'SOFT' 40;
        display:-webkit-box;
        -webkit-box-orient:vertical;
        -webkit-line-clamp:${t.lines};`}
    >
      {title}
    </p>
  </div>

  {/* Bottom: monogram + category */}
  <div class="relative z-[1] flex items-end justify-between">
    <span class="tracking-[0.18em] font-bold opacity-70 uppercase" style={`font-size:${t.monoFont + 1}px;`}>
      AUPA · AB
    </span>
    {size !== 'xs' && categoryLabel[category] && (
      <span class="tracking-[0.06em] font-medium opacity-80 uppercase" style={`font-size:${t.monoFont + 1}px;`}>
        {categoryLabel[category]}
      </span>
    )}
  </div>
</div>
