---
// Editorial auto-thumbnail.
//
// Was: title rendered as large type on a colored card. Problem: every
// ArticleCard variant ALSO renders the title as <h2>, so the visible title
// appeared twice per card. Now: a typographic source-brand chip with NO
// title text — the card body owns the title.
//
// Density adapts to size:
//   xs / sm  → minimalist (brand color + big monogram only). At ≤220 px
//              the date/source/category strips don't fit gracefully — text
//              wraps onto two or three lines and looks broken. The card
//              body already carries that metadata, so we drop it here.
//   md / lg  → rich layout (top strip with source name + date, big center
//              monogram, bottom strip with category + AUPA · AB). The
//              ≥280 px thumb has enough width for the strips to read.
import { getSourceMeta } from '~/lib/sources';
import type { ArticleCategory } from '@shared/types';

type Size = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  id: string;
  title: string; // aria-label only — never rendered as visible text
  category: ArticleCategory;
  dateLabel?: string;
  sourceSlug: string;
  sourceName: string;
  size?: Size;
  class?: string;
}

const { id, title, category, dateLabel, sourceSlug, sourceName, size = 'md', class: className } = Astro.props;
const meta = getSourceMeta(sourceSlug);

const tokens: Record<Size, {
  padding: number;
  smallMono: number;
  bigMono: number;
}> = {
  xs: { padding: 6,  smallMono: 8,  bigMono: 26 },
  sm: { padding: 10, smallMono: 9,  bigMono: 38 },
  md: { padding: 20, smallMono: 10, bigMono: 72 },
  lg: { padding: 28, smallMono: 11, bigMono: 120 },
};
const t = tokens[size];

const isHero = size === 'lg';
const isMinimal = size === 'xs' || size === 'sm';

const padStyle = isHero ? 'padding: clamp(20px, 3vw, 36px)' : `padding: ${t.padding}px`;
const bigMonoSize = isHero
  ? 'font-size: clamp(64px, 11vw, 120px)'
  : isMinimal
    ? `font-size: clamp(${t.bigMono - 6}px, 12vw, ${t.bigMono + 6}px)`
    : `font-size: ${t.bigMono}px`;

const bg = meta.color;
const fg = '#FAFAF7';
const filFG = '#FFFFFF';

const categoryLabel: Record<ArticleCategory, string> = {
  match: 'Match',
  mercato: 'Mercato',
  coulisses: 'Coulisses',
  espoirs: 'Espoirs',
  pays_basque: 'Pays Basque',
  autre: '',
};

type MotifKind = 'rugby' | 'arrows' | 'dots' | 'wave' | 'lines' | 'lauburu';
const motifFor: Record<ArticleCategory, MotifKind> = {
  match: 'rugby',
  mercato: 'arrows',
  espoirs: 'dots',
  pays_basque: 'wave',
  coulisses: 'lines',
  autre: 'lauburu',
};
const motif = motifFor[category];
---

<div
  class:list={['relative w-full h-full overflow-hidden flex flex-col justify-center items-center', className]}
  style={`background:${bg}; color:${fg}; ${padStyle};`}
  role="img"
  aria-label={`${title} — vignette ${sourceName}`}
>
  {/* Decorative motif, varies by category — purely visual variety */}
  {motif === 'rugby' && (
    <svg class="absolute -right-[10%] top-1/2 -translate-y-1/2 opacity-[0.10] pointer-events-none" width="120%" height="120%" viewBox="0 0 100 100" aria-hidden="true">
      <ellipse cx="50" cy="50" rx="38" ry="22" fill="none" stroke={filFG} stroke-width="0.7" transform="rotate(-22 50 50)" />
      <ellipse cx="50" cy="50" rx="38" ry="22" fill="none" stroke={filFG} stroke-width="0.7" transform="rotate(22 50 50)" />
      <line x1="20" y1="50" x2="80" y2="50" stroke={filFG} stroke-width="0.7" />
      <line x1="35" y1="46" x2="35" y2="54" stroke={filFG} stroke-width="0.7" />
      <line x1="45" y1="46" x2="45" y2="54" stroke={filFG} stroke-width="0.7" />
      <line x1="55" y1="46" x2="55" y2="54" stroke={filFG} stroke-width="0.7" />
      <line x1="65" y1="46" x2="65" y2="54" stroke={filFG} stroke-width="0.7" />
    </svg>
  )}
  {motif === 'arrows' && (
    <svg class="absolute inset-0 opacity-[0.11] pointer-events-none" width="100%" height="100%" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      {Array.from({ length: 5 }).map((_, i) => (
        <g transform={`translate(${i * 50 - 20} ${i * 30 - 30})`}>
          <path d={`M0 80 L60 80 M50 75 L60 80 L50 85`} stroke={filFG} stroke-width="1.5" fill="none" stroke-linecap="round" />
        </g>
      ))}
    </svg>
  )}
  {motif === 'dots' && (
    <svg class="absolute inset-0 opacity-[0.12] pointer-events-none" width="100%" height="100%" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      {Array.from({ length: 6 }).flatMap((_, r) =>
        Array.from({ length: 8 }).map((_, c) => (
          <circle cx={c * 30 + 15} cy={r * 32 + 16} r={c % 2 === 0 ? 2 : 3} fill={filFG} />
        ))
      )}
    </svg>
  )}
  {motif === 'wave' && (
    <svg class="absolute inset-0 opacity-[0.16] pointer-events-none" width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 110 Q 50 70, 100 110 T 200 110 T 300 110 T 400 110 V 200 H 0 Z" fill={filFG} />
      <path d="M0 140 Q 50 110, 100 140 T 200 140 T 300 140 T 400 140 V 200 H 0 Z" fill={filFG} opacity="0.5" />
    </svg>
  )}
  {motif === 'lines' && (
    <svg class="absolute inset-0 opacity-[0.09] pointer-events-none" width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="none" aria-hidden="true">
      {Array.from({ length: 6 }).map((_, i) => (
        <line x1={i * 80} y1="0" x2={i * 80 - 120} y2="200" stroke={filFG} stroke-width="24" />
      ))}
    </svg>
  )}
  {motif === 'lauburu' && (
    <svg class="absolute -right-[10%] top-1/2 -translate-y-1/2 opacity-[0.09] pointer-events-none" width="120%" height="120%" viewBox="0 0 100 100" aria-hidden="true">
      <g stroke={filFG} fill="none" stroke-width="0.7">
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(90 50 50)" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(180 50 50)" />
        <path d="M50 50 C50 30, 30 30, 30 50 C30 40, 40 40, 50 50 Z" transform="rotate(270 50 50)" />
      </g>
    </svg>
  )}

  {isMinimal ? (
    /* Compact layout (xs/sm): big centered monogram only. No text strips —
       at this width "SUD OUEST" + "13 MAI 2026" wrap onto multiple lines
       and look broken. The card body already shows source name and date. */
    <span
      class="relative z-[1] font-serif font-semibold leading-none"
      aria-hidden="true"
      style={`color:${fg};
        ${bigMonoSize};
        letter-spacing:-0.04em;
        font-variation-settings:'opsz' 144;`}
    >
      {meta.mono}
    </span>
  ) : (
    /* Rich layout (md/lg): top strip + big mono + bottom strip */
    <div class="absolute inset-0 flex flex-col justify-between" style={padStyle}>
      <div class="relative z-[1] flex items-center justify-between">
        <span class="uppercase font-semibold tracking-[0.12em] opacity-[0.85]" style={`font-size:${t.smallMono + 1}px;`}>
          {sourceName}
        </span>
        {dateLabel && (
          <span class="uppercase tracking-[0.08em] font-medium opacity-70" style={`font-size:${t.smallMono + 1}px;`}>
            {dateLabel}
          </span>
        )}
      </div>

      <div class="relative z-[1] flex-1 flex items-center justify-center">
        <span
          class="font-serif font-semibold leading-none"
          aria-hidden="true"
          style={`color:${fg};
            ${bigMonoSize};
            letter-spacing:-0.04em;
            font-variation-settings:'opsz' 144;
            opacity:0.95;`}
        >
          {meta.mono}
        </span>
      </div>

      <div class="relative z-[1] flex items-end justify-between gap-2">
        {categoryLabel[category] ? (
          <span class="uppercase tracking-[0.12em] font-semibold opacity-85" style={`font-size:${t.smallMono + 1}px;`}>
            {categoryLabel[category]}
          </span>
        ) : (
          <span aria-hidden="true">&nbsp;</span>
        )}
        <span class="tracking-[0.18em] font-bold opacity-60 uppercase" style={`font-size:${t.smallMono}px;`}>
          AUPA · AB
        </span>
      </div>
    </div>
  )}
</div>
