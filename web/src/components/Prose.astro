---
// Wrapper for long-form institutional content. Caps width at reading-max.
interface Props {
  title: string;
  kicker?: string;
  updated?: string;
}
const { title, kicker, updated } = Astro.props;
---

<div class="max-w-reading mx-auto px-4 md:px-6 pt-10 md:pt-16 pb-16">
  {kicker && <span class="t-meta text-aviron">{kicker}</span>}
  <h1 class="mt-1 mb-3 font-serif font-semibold text-[32px] md:text-[44px] leading-[1.06]" style="font-variation-settings:'opsz' 96, 'SOFT' 40;">
    {title}
  </h1>
  {updated && <p class="text-[12.5px] text-fg-tertiary mb-8">Dernière mise à jour : {updated}</p>}
  <div class="text-[17px] leading-[1.7] text-fg space-y-5 prose-institutional">
    <slot />
  </div>
</div>

<style>
  .prose-institutional :global(h2) {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 1.625rem;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .prose-institutional :global(h3) {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-institutional :global(p) { margin: 0 0 1.25rem; text-wrap: pretty; }
  .prose-institutional :global(ul),
  .prose-institutional :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-institutional :global(li) { margin: 0.25rem 0; }
  .prose-institutional :global(a) {
    color: rgb(var(--c-aviron));
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-institutional :global(strong) { font-weight: 600; }
  .prose-institutional :global(hr) {
    border: 0;
    border-top: 1px solid rgb(var(--border-subtle));
    margin: 2.5rem 0;
  }
  .prose-institutional :global(blockquote) {
    border-left: 3px solid rgb(var(--c-aviron));
    padding-left: 1rem;
    font-style: italic;
    color: rgb(var(--fg-secondary));
  }
</style>
