---
import '~/styles/globals.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  author?: string;
  category?: string;
  tags?: string[];
  sourceName?: string;
  sourceUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Agrégateur d'actualités de l'Aviron Bayonnais. Non-officiel, fait par des supporters, pour des supporters.",
  ogImage,
  canonical,
  type = 'website',
  publishedAt,
  author,
  category,
  tags = [],
  sourceName,
  sourceUrl,
  noindex = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://aupa-ab.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullTitle = title === 'AUPA AB' ? title : `${title} — AUPA AB`;
// OG image — defaults to the brand SVG; article pages can pass a per-slug URL
// (the /og/[slug].png endpoint redirects to /og-default.svg in V1 and to a
// Cloudinary-generated PNG in V2).
const finalOg = ogImage ?? `${siteUrl}/og-default.svg`;

// Plausible (cookieless, exempt from strict CNIL consent). Loaded directly when configured.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;

// Umami self-hosted analytics — privacy-first, no cookies, no consent
// banner required. Configured via two PUBLIC_ env vars so they're inlined
// at build time and shipped as attributes.
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0B2545" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0E1116" media="(prefers-color-scheme: dark)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="apple-mobile-web-app-title" content="AUPA AB" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts: native system stack.
         Body uses San Francisco (macOS/iOS), Segoe UI (Windows), Roboto (Android)
         via system-ui. Headings use New York (macOS/iOS 13+), Iowan Old Style or
         Charter on older Mac, Georgia on Windows. Zero font download, optical
         sizing automatic, native antialiasing. Switched from Fraunces+Inter on
         user feedback ("la police est dégueulasse"). -->
    {/* No Google Fonts — fonts are system. */}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={finalOg} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AUPA AB" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AupaAB" />

    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt} />
    )}
    {type === 'article' && author && <meta property="article:author" content={author} />}
    {type === 'article' && category && <meta property="article:section" content={category} />}
    {type === 'article' &&
      tags.map((tag) => <meta property="article:tag" content={tag} />)}

    {type === 'article' && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'NewsArticle',
          headline: title,
          image: finalOg,
          datePublished: publishedAt,
          author: author ? { '@type': 'Person', name: author } : undefined,
          publisher: sourceName
            ? { '@type': 'Organization', name: sourceName }
            : undefined,
          isBasedOn: sourceUrl,
          url: canonicalUrl,
        })}
      />
    )}

    {plausibleDomain && (
      <script is:inline defer src="https://plausible.io/js/script.js" data-domain={plausibleDomain}></script>
    )}

    {umamiSrc && umamiWebsiteId && (
      <script is:inline defer src={umamiSrc} data-website-id={umamiWebsiteId}></script>
    )}

    <!-- Theme bootstrap (no flash) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('aupa-theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefers ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-aviron focus:px-4 focus:py-2 focus:text-white"
    >
      Aller au contenu
    </a>
    <slot />
  </body>
</html>
