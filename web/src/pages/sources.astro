---
import SiteShell from '~/layouts/SiteShell.astro';
import { listActiveSources, listSourcesWithArticles, listArticles } from '~/lib/data';
import { getSourceMeta } from '~/lib/sources';

// Source-by-source overview, used as both transparency page (which press
// outlets we crawl) and dashboard (last scan, current article count).
const [active, withArticles, allArticles] = await Promise.all([
  listActiveSources(),
  listSourcesWithArticles(),
  listArticles({ limit: 100 }),
]);

const countBySlug = new Map(withArticles.map((s) => [s.slug, s.count]));
const totalArticles = allArticles.length;

// Sort: sources with articles first (by count desc), then dormant ones.
const sorted = [...active].sort((a, b) => {
  const ca = countBySlug.get(a.slug) ?? 0;
  const cb = countBySlug.get(b.slug) ?? 0;
  if (ca !== cb) return cb - ca;
  return a.name.localeCompare(b.name);
});
---

<SiteShell
  title="Sources surveillées"
  description="La liste complète des médias dont nous agrégeons les flux RSS. Transparence totale : vous saurez toujours d'où vient une info."
>
  <div class="max-w-reading mx-auto px-4 md:px-6 pt-10 md:pt-16 pb-16">
    <span class="t-meta text-aviron">Transparence</span>
    <h1 class="mt-1 mb-4 font-serif font-semibold text-[34px] md:text-[44px] leading-[1.06]" style="font-variation-settings:'opsz' 96, 'SOFT' 40;">
      Les médias qu'on lit pour vous
    </h1>
    <p class="text-[17px] leading-[1.6] text-fg-secondary mb-8">
      AUPA AB ne produit pas d'actualités. On collecte, on filtre, on contextualise, on renvoie vers la source. Voici la liste exhaustive. Si vous éditez un de ces médias et souhaitez qu'on retire votre flux, <a href="/contact-retrait" class="text-aviron underline">écrivez-nous</a> — réponse sous 24&nbsp;h.
    </p>

    {/* KPI row */}
    <div class="grid grid-cols-3 gap-3 md:gap-4 mb-10">
      <div class="px-4 py-4 rounded-lg bg-bg-elevated border border-border-subtle">
        <div class="font-serif font-semibold text-[28px] md:text-[34px] leading-none text-aviron tnum">{active.length}</div>
        <div class="text-[11.5px] md:text-[13px] text-fg-secondary mt-1">médias surveillés</div>
      </div>
      <div class="px-4 py-4 rounded-lg bg-bg-elevated border border-border-subtle">
        <div class="font-serif font-semibold text-[28px] md:text-[34px] leading-none text-aviron tnum">{totalArticles}</div>
        <div class="text-[11.5px] md:text-[13px] text-fg-secondary mt-1">articles agrégés</div>
      </div>
      <div class="px-4 py-4 rounded-lg bg-bg-elevated border border-border-subtle">
        <div class="font-serif font-semibold text-[28px] md:text-[34px] leading-none text-aviron tnum">15&nbsp;<span class="text-[14px] text-fg-secondary">min</span></div>
        <div class="text-[11.5px] md:text-[13px] text-fg-secondary mt-1">fréquence de scan</div>
      </div>
    </div>

    <ul class="list-none m-0 p-0 grid grid-cols-1 gap-3">
      {sorted.map((s) => {
        const meta = getSourceMeta(s.slug);
        const count = countBySlug.get(s.slug) ?? 0;
        const lastScan = s.last_fetched_at
          ? new Date(s.last_fetched_at).toLocaleString('fr-FR', { dateStyle: 'short', timeStyle: 'short' })
          : 'jamais';
        return (
          <li class="flex items-center gap-4 p-4 rounded-lg bg-bg-elevated border border-border-subtle hover:border-border-default transition-colors">
            <span
              class="inline-flex items-center justify-center w-12 h-12 rounded-md text-white font-bold text-sm shrink-0"
              style={`background:${meta.color};`}
              aria-hidden="true"
            >{meta.mono}</span>
            <div class="flex-1 min-w-0">
              <a href={`https://${s.domain}`} target="_blank" rel="noopener noreferrer" class="font-medium text-fg hover:text-aviron text-[15px]">
                {s.name}
              </a>
              <div class="text-[12px] text-fg-secondary">{s.domain}</div>
              <div class="text-[11px] text-fg-tertiary mt-0.5">Dernier scan : {lastScan}</div>
            </div>
            <div class="text-right shrink-0">
              {count > 0 ? (
                <a href={`/?src=${s.slug}`} class="inline-flex flex-col items-end gap-0.5 hover:opacity-80">
                  <span class="font-serif font-semibold text-[24px] leading-none text-aviron tnum">{count}</span>
                  <span class="text-[10.5px] uppercase tracking-[0.06em] text-fg-tertiary">article{count > 1 ? 's' : ''}</span>
                </a>
              ) : (
                <span class="inline-flex flex-col items-end gap-0.5 opacity-50" title="Pas d'article AB dans le flux RSS actuel">
                  <span class="font-serif font-semibold text-[24px] leading-none text-fg-tertiary tnum">0</span>
                  <span class="text-[10.5px] uppercase tracking-[0.06em] text-fg-tertiary">en veille</span>
                </span>
              )}
            </div>
          </li>
        );
      })}
    </ul>

  </div>
</SiteShell>
