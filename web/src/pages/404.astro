---
import SiteShell from '~/layouts/SiteShell.astro';
import Button from '~/components/atoms/Button.astro';
import Lauburu from '~/components/atoms/Lauburu.astro';
---

<SiteShell title="Page introuvable" description="Cette page n'existe pas ou a été déplacée." noindex>
  <div class="max-w-reading mx-auto px-4 md:px-6 py-24 text-center">
    <Lauburu size={64} stroke="rgb(var(--c-aviron))" opacity={0.6} />
    <p class="mt-6 t-meta text-fg-tertiary">Erreur 404</p>
    <h1 class="mt-2 mb-4 font-serif font-semibold text-[32px] md:text-[40px]" style="font-variation-settings:'opsz' 96, 'SOFT' 30;">
      Cette page n'existe pas ou a été déplacée
    </h1>
    <p class="text-[16px] text-fg-secondary max-w-[420px] mx-auto mb-8">
      Peut-être un lien périmé. Peut-être un article retiré. Peut-être un copier-coller malheureux. Aucun rapport avec votre vie, en tout cas.
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <Button variant="primary" href="/" icon="home">Retour à l'accueil</Button>
      <Button variant="secondary" href="/recherche" icon="search">Recherche</Button>
    </div>
  </div>
</SiteShell>
