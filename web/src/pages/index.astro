---
// Home = actualités list. Was an editorial home with hero card, KPIs,
// themed sections and a Tribune mock; collapsed into the feed because the
// mocks read as fake and the editorial framing got in the way of the news.
// To restore a fixture banner here: add a `fixtures` table populated from
// LNR or scraped from a public source.
import SiteShell from '~/layouts/SiteShell.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import NextMatchBanner from '~/components/NextMatchBanner.astro';
import Button from '~/components/atoms/Button.astro';
import { listArticles, listSourcesWithArticles, listActiveSources, getNextFixture } from '~/lib/data';
import type { ArticleCategory } from '@shared/types';

const url = Astro.url;
const cat = (url.searchParams.get('cat') ?? 'all') as ArticleCategory | 'all';
const src = url.searchParams.get('src') ?? 'all';
type Since = 'all' | 'today' | 'week' | 'month';
const since = (url.searchParams.get('since') ?? 'all') as Since;

const allCats: Array<{ key: ArticleCategory | 'all'; label: string }> = [
  { key: 'all', label: 'Tout' },
  { key: 'match', label: 'Match' },
  { key: 'mercato', label: 'Mercato' },
  { key: 'coulisses', label: 'Coulisses' },
  { key: 'espoirs', label: 'Espoirs' },
  { key: 'pays_basque', label: 'Pays Basque' },
  { key: 'autre', label: 'Autre' },
];

const sinceFilters: Array<{ key: Since; label: string }> = [
  { key: 'all',   label: 'Depuis toujours' },
  { key: 'today', label: '24 h' },
  { key: 'week',  label: '7 jours' },
  { key: 'month', label: '30 jours' },
];

const articles = await listArticles({
  cat: cat === 'all' ? undefined : cat,
  src: src === 'all' ? undefined : src,
  since: since === 'all' ? undefined : since,
  limit: 50,
});

const sourceList = await listSourcesWithArticles();

// Number of sources we actively crawl (the "we're watching X medias" number
// shown under the H1). Distinct from listSourcesWithArticles, which is the
// shorter set used by the filter dropdown.
const activeSourceCount = (await listActiveSources()).length;
const nextFixture = await getNextFixture();

// Build href preserving the OTHER filters
const buildHref = (overrides: Partial<{ cat: ArticleCategory | 'all'; src: string; since: Since }>) => {
  const next = {
    cat: overrides.cat ?? cat,
    src: overrides.src ?? src,
    since: overrides.since ?? since,
  };
  const params = new URLSearchParams();
  if (next.cat !== 'all') params.set('cat', next.cat);
  if (next.src !== 'all') params.set('src', next.src);
  if (next.since !== 'all') params.set('since', next.since);
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
};
---

<SiteShell
  title="AUPA AB"
  description="Toute l'actualité de l'Aviron Bayonnais, agrégée depuis les principaux médias, mise à jour toutes les 15 minutes."
>
  <div class="max-w-container mx-auto px-4 md:px-8 pt-4 md:pt-6 pb-10 md:pb-20">
    <NextMatchBanner fixture={nextFixture} />

    {/* Page intro — minimal, just enough to anchor the feed */}
    <header class="mt-5 md:mt-7 mb-5 md:mb-7">
      <span class="t-meta text-aviron">Actualités</span>
      <h1 class="mt-1 mb-2 font-serif font-semibold text-[32px] md:text-[48px] leading-[1.04] tracking-[-0.015em]" style="font-variation-settings:'opsz' 144, 'SOFT' 40; text-wrap:balance;">
        L'Aviron Bayonnais, sans en perdre une miette.
      </h1>
      <p class="m-0 text-[14.5px] md:text-[16.5px] text-fg-secondary max-w-reading">
        {activeSourceCount}&nbsp;sources actualisées toutes les 15&nbsp;minutes, et résumées en quelques mots.
      </p>
    </header>

    {/* Filters bar (sticky under header) */}
    <form
      method="get"
      class="sticky top-14 md:top-[72px] z-10 -mx-4 md:-mx-8 px-4 md:px-8 py-3 bg-bg-default border-b border-border-subtle mb-4"
      aria-label="Filtres des articles"
    >
      <div class="flex gap-2 overflow-x-auto pb-1" role="tablist" aria-label="Catégorie">
        {allCats.map((c) => {
          const isActive = c.key === cat;
          return (
            <a
              href={buildHref({ cat: c.key })}
              role="tab"
              aria-selected={isActive ? 'true' : 'false'}
              class:list={[
                'px-3.5 py-2 text-[13px] font-medium whitespace-nowrap rounded-full transition-colors',
                isActive
                  ? 'bg-fg text-bg-default border border-fg'
                  : 'border border-border-subtle text-fg-secondary hover:text-fg',
              ]}
            >
              {c.label}
            </a>
          );
        })}
      </div>

      {/* Period chips — second row */}
      <div class="flex gap-2 overflow-x-auto pb-1 mt-2" role="tablist" aria-label="Période">
        {sinceFilters.map((s) => {
          const isActive = s.key === since;
          return (
            <a
              href={buildHref({ since: s.key })}
              role="tab"
              aria-selected={isActive ? 'true' : 'false'}
              class:list={[
                'px-3 py-1.5 text-[12px] font-medium whitespace-nowrap rounded-full transition-colors',
                isActive
                  ? 'bg-aviron text-white dark:text-night border border-aviron'
                  : 'border border-border-subtle text-fg-tertiary hover:text-fg',
              ]}
            >
              {s.label}
            </a>
          );
        })}
        <span class="ml-auto self-center text-[12px] text-fg-secondary tnum hidden md:inline">
          {articles.length} article{articles.length > 1 ? 's' : ''}
        </span>
      </div>

      <div class="hidden md:flex gap-3 mt-3 items-center">
        <label class="text-[13px] text-fg-secondary">
          Source
          <select
            name="src"
            class="ml-2 px-3 py-1.5 text-[13px] bg-bg-elevated border border-border-subtle rounded-md text-fg"
            onchange="this.form.submit()"
          >
            <option value="all">Toutes les sources</option>
            {sourceList.map((s) => (
              <option value={s.slug} selected={src === s.slug}>{s.name} ({s.count})</option>
            ))}
          </select>
        </label>
        {cat !== 'all' && <input type="hidden" name="cat" value={cat} />}
        {since !== 'all' && <input type="hidden" name="since" value={since} />}
      </div>
    </form>

    {/* Article list */}
    <div>
      {articles.length === 0 ? (
        <div class="py-16 text-center text-fg-secondary">
          <p class="m-0 mb-2">Aucun article ne correspond à ces filtres.</p>
          <a href="/" class="text-aviron underline text-[13px]">Réinitialiser tout</a>
        </div>
      ) : (
        articles.map((a) => (
          <ArticleCard
            variant="row"
            slug={a.slug}
            title={a.ai_title ?? a.title}
            lede={a.lede ?? a.excerpt}
            category={a.category}
            sourceSlug={a.source.slug}
            sourceName={a.source.name}
            timeLabel={a.time_label}
            dateLabel={a.date_label}
            readingMin={a.reading_min}
            commentCount={a.comment_count}
            coverImageUrl={a.cover_image_url}
          />
        ))
      )}
    </div>

    {articles.length >= 50 && (
      <div class="mt-10 flex justify-center">
        <Button variant="secondary" size="lg" iconRight="arrowRight">
          Charger plus d'articles
        </Button>
      </div>
    )}

    {/* Non-officiel pinned reminder */}
    <div class="mt-14 md:mt-20 pt-6 border-t border-border-subtle">
      <p class="m-0 text-[12.5px] text-fg-tertiary text-center max-w-reading mx-auto leading-relaxed">
        <strong class="text-fg-secondary">Site non-officiel.</strong> AUPA AB n'a aucun lien juridique avec l'Aviron Bayonnais. Les articles sont des extraits courts (≤ 350 caractères) avec lien sortant vers la source originale. Vous êtes éditeur et souhaitez un retrait&nbsp;? <a href="/contact-retrait" class="text-aviron underline">Écrivez-nous</a>.
      </p>
    </div>
  </div>
</SiteShell>
