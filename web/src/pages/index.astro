---
// Home = actualités list. Was: editorial home with hero, KPIs, themed
// sections, Tribune placeholder. User collapsed it into the feed because
// it's more direct. The MatchBanner ("Prochain match · J-3, AB vs ST,
// Samedi 17 mai · 21h05, Stade Jean-Dauger") was removed in a follow-up:
// it was fully mocked from @shared/mock with no real fixture data behind
// it, and showing fake countdown/venue/diffusion data is worse than not
// showing it at all. To bring it back: add a `fixtures` table to Supabase
// or wire a LNR/Top14 fixture source via the crawler.
import SiteShell from '~/layouts/SiteShell.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import Button from '~/components/atoms/Button.astro';
import { listArticles, listSourcesWithArticles } from '~/lib/data';
import type { ArticleCategory } from '@shared/types';

const url = Astro.url;
const cat = (url.searchParams.get('cat') ?? 'all') as ArticleCategory | 'all';
const src = url.searchParams.get('src') ?? 'all';

const allCats: Array<{ key: ArticleCategory | 'all'; label: string }> = [
  { key: 'all', label: 'Tout' },
  { key: 'match', label: 'Match' },
  { key: 'mercato', label: 'Mercato' },
  { key: 'coulisses', label: 'Coulisses' },
  { key: 'espoirs', label: 'Espoirs' },
  { key: 'pays_basque', label: 'Pays Basque' },
  { key: 'autre', label: 'Autre' },
];

const articles = await listArticles({
  cat: cat === 'all' ? undefined : cat,
  src: src === 'all' ? undefined : src,
  limit: 50,
});

const sourceList = await listSourcesWithArticles();

// Build href preserving the OTHER filter
const filterHref = (catKey: ArticleCategory | 'all') => {
  const params = new URLSearchParams();
  if (catKey !== 'all') params.set('cat', catKey);
  if (src !== 'all') params.set('src', src);
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
};
---

<SiteShell
  title="AUPA AB"
  description="Toute l'actualité de l'Aviron Bayonnais, agrégée depuis les principaux médias, mise à jour toutes les 15 minutes."
>
  <div class="max-w-container mx-auto px-4 md:px-8 pt-4 md:pt-6 pb-10 md:pb-20">
    {/* Page intro — minimal, just enough to anchor the feed */}
    <header class="mt-2 md:mt-4 mb-5 md:mb-7">
      <span class="t-meta text-aviron">Actualités</span>
      <h1 class="mt-1 mb-2 font-serif font-semibold text-[32px] md:text-[48px] leading-[1.04] tracking-[-0.015em]" style="font-variation-settings:'opsz' 144, 'SOFT' 40; text-wrap:balance;">
        L'Aviron Bayonnais, en continu
      </h1>
    </header>

    {/* Filters bar (sticky under header) */}
    <form
      method="get"
      class="sticky top-14 md:top-[72px] z-10 -mx-4 md:-mx-8 px-4 md:px-8 py-3 bg-bg-default border-b border-border-subtle mb-4"
      aria-label="Filtres des articles"
    >
      <div class="flex gap-2 overflow-x-auto pb-1" role="tablist" aria-label="Catégorie">
        {allCats.map((c) => {
          const isActive = c.key === cat;
          return (
            <a
              href={filterHref(c.key)}
              role="tab"
              aria-selected={isActive ? 'true' : 'false'}
              class:list={[
                'px-3.5 py-2 text-[13px] font-medium whitespace-nowrap rounded-full transition-colors',
                isActive
                  ? 'bg-fg text-bg-default border border-fg'
                  : 'border border-border-subtle text-fg-secondary hover:text-fg',
              ]}
            >
              {c.label}
            </a>
          );
        })}
      </div>
      <div class="hidden md:flex gap-3 mt-3 items-center">
        <label class="text-[13px] text-fg-secondary">
          Source
          <select
            name="src"
            class="ml-2 px-3 py-1.5 text-[13px] bg-bg-elevated border border-border-subtle rounded-md text-fg"
            onchange="this.form.submit()"
          >
            <option value="all">Toutes les sources</option>
            {sourceList.map((s) => (
              <option value={s.slug} selected={src === s.slug}>{s.name} ({s.count})</option>
            ))}
          </select>
        </label>
        {cat !== 'all' && <input type="hidden" name="cat" value={cat} />}
        <span class="ml-auto text-[12.5px] text-fg-secondary tnum">
          {articles.length} article{articles.length > 1 ? 's' : ''}
        </span>
      </div>
    </form>

    {/* Article list */}
    <div>
      {articles.length === 0 ? (
        <p class="py-16 text-center text-fg-secondary">
          Aucun article ne correspond à ces filtres. <a href="/" class="text-aviron underline">Réinitialiser</a>.
        </p>
      ) : (
        articles.map((a) => (
          <ArticleCard
            variant="row"
            slug={a.slug}
            title={a.title}
            lede={a.lede ?? a.excerpt}
            category={a.category}
            sourceSlug={a.source.slug}
            sourceName={a.source.name}
            timeLabel={a.time_label}
            dateLabel={a.date_label}
            readingMin={a.reading_min}
            commentCount={a.comment_count}
          />
        ))
      )}
    </div>

    {articles.length >= 50 && (
      <div class="mt-10 flex justify-center">
        <Button variant="secondary" size="lg" iconRight="arrowRight">
          Charger plus d'articles
        </Button>
      </div>
    )}

    {/* Non-officiel pinned reminder */}
    <div class="mt-14 md:mt-20 pt-6 border-t border-border-subtle">
      <p class="m-0 text-[12.5px] text-fg-tertiary text-center max-w-reading mx-auto leading-relaxed">
        <strong class="text-fg-secondary">Site non-officiel.</strong> AUPA AB n'a aucun lien juridique avec l'Aviron Bayonnais. Les articles sont des extraits courts (≤ 350 caractères) avec lien sortant vers la source originale. Vous êtes éditeur et souhaitez un retrait&nbsp;? <a href="/contact-retrait" class="text-aviron underline">Écrivez-nous</a>.
      </p>
    </div>
  </div>
</SiteShell>
