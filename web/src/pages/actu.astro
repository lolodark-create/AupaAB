---
import SiteShell from '~/layouts/SiteShell.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import Button from '~/components/atoms/Button.astro';
import { listArticles, listActiveSources } from '~/lib/data';
import type { ArticleCategory } from '@shared/types';

const url = Astro.url;
const cat = (url.searchParams.get('cat') ?? 'all') as ArticleCategory | 'all';
const src = url.searchParams.get('src') ?? 'all';

const allCats: Array<{ key: ArticleCategory | 'all'; label: string }> = [
  { key: 'all', label: 'Tout' },
  { key: 'match', label: 'Match' },
  { key: 'mercato', label: 'Mercato' },
  { key: 'coulisses', label: 'Coulisses' },
  { key: 'espoirs', label: 'Espoirs' },
  { key: 'pays_basque', label: 'Pays Basque' },
  { key: 'autre', label: 'Autre' },
];

const filtered = await listArticles({
  cat: cat === 'all' ? undefined : cat,
  src: src === 'all' ? undefined : src,
  limit: 50,
});

const sourceList = await listActiveSources();
---

<SiteShell
  title="Actualités"
  description="Toutes les news de l'Aviron Bayonnais agrégées depuis les principaux médias. Filtrez par catégorie, source ou période."
>
  <div class="max-w-container mx-auto px-4 md:px-8 pt-6 md:pt-10 pb-10 md:pb-20">
    <header class="mb-6 md:mb-10">
      <span class="t-meta text-aviron">Actualités</span>
      <h1 class="mt-1 mb-2 font-serif font-semibold text-[34px] md:text-[56px] leading-[1.04] tracking-[-0.015em]" style="font-variation-settings:'opsz' 144, 'SOFT' 40; text-wrap:balance;">
        Toutes les news de l'Aviron Bayonnais
      </h1>
      <p class="m-0 text-[15px] md:text-lg text-fg-secondary max-w-reading">
        Sources surveillées, scannées toutes les 15 minutes. On garde ce qui mérite, on jette le reste. <em>Promis.</em>
      </p>
    </header>

    {/* Filters bar */}
    <form
      method="get"
      class="sticky top-14 md:top-[72px] z-10 -mx-4 md:-mx-8 px-4 md:px-8 py-3 bg-bg-default border-b border-border-subtle mb-4"
      aria-label="Filtres des articles"
    >
      <div class="flex gap-2 overflow-x-auto pb-1" role="tablist" aria-label="Catégorie">
        {allCats.map((c) => {
          const isActive = c.key === cat;
          const href = c.key === 'all' ? '/actu' : `/actu?cat=${c.key}`;
          return (
            <a
              href={src !== 'all' ? `${href}${href.includes('?') ? '&' : '?'}src=${src}` : href}
              role="tab"
              aria-selected={isActive ? 'true' : 'false'}
              class:list={[
                'px-3.5 py-2 text-[13px] font-medium whitespace-nowrap rounded-full transition-colors',
                isActive
                  ? 'bg-fg text-bg-default border border-fg'
                  : 'border border-border-subtle text-fg-secondary hover:text-fg',
              ]}
            >
              {c.label}
            </a>
          );
        })}
      </div>
      <div class="hidden md:flex gap-3 mt-3 items-center">
        <label class="text-[13px] text-fg-secondary">
          Source
          <select
            name="src"
            class="ml-2 px-3 py-1.5 text-[13px] bg-bg-elevated border border-border-subtle rounded-md text-fg"
            onchange="this.form.submit()"
          >
            <option value="all">Toutes les sources</option>
            {sourceList.map((s) => (
              <option value={s.slug} selected={src === s.slug}>{s.name}</option>
            ))}
          </select>
        </label>
        {cat !== 'all' && <input type="hidden" name="cat" value={cat} />}
        <span class="ml-auto text-[12.5px] text-fg-secondary tnum">
          {filtered.length} article{filtered.length > 1 ? 's' : ''}
        </span>
      </div>
    </form>

    {/* List */}
    <div>
      {filtered.length === 0 ? (
        <p class="py-16 text-center text-fg-secondary">Aucun article ne correspond à ces filtres. <a href="/actu" class="text-aviron underline">Réinitialiser</a>.</p>
      ) : (
        filtered.map((a) => (
          <ArticleCard
            variant="row"
            slug={a.slug}
            title={a.title}
            lede={a.lede ?? a.excerpt}
            category={a.category}
            sourceSlug={a.source.slug}
            sourceName={a.source.name}
            timeLabel={a.time_label}
            dateLabel={a.date_label}
            readingMin={a.reading_min}
            commentCount={a.comment_count}
          />
        ))
      )}
    </div>

    {filtered.length > 0 && (
      <div class="mt-10 flex justify-center">
        <Button variant="secondary" size="lg" iconRight="arrowRight">
          Charger plus d'articles
        </Button>
      </div>
    )}
  </div>
</SiteShell>
